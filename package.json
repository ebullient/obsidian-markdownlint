{
  "name": "obsidian-markdownlint",
  "version": "1.0.1",
  "description": "Use markdownlint to make the contents of your files more consistent",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "fix": "npx @biomejs/biome check --write ./src",
    "format": "npx @biomejs/biome format ./src",
    "eslint": "npx eslint",
    "lint": "npx @biomejs/biome lint ./src",
    "prebuild": "npx @biomejs/biome check ./src",
    "build": "node esbuild.config.mjs production",
    "postbuild": "cp -v manifest.json README.md styles.css build || ( copy \"manifest.json\" \"build\" & copy \"README.md\" \"build\" & copy \"styles.css\" \"build\" )",
    "preversion": "npm run build",
    "version": "auto-changelog -p",
    "brat-notes": "run() { auto-changelog --stdout --hide-credit --hide-empty-releases --template .github/changelog.hbs -v $1 --starting-version $1  > release-notes.md; }; run"
  },
  "keywords": [
    "obsidian",
    "markdownlint"
  ],
  "author": "ebullient",
  "repository": "github.com:ebullient/obsidian-markdownlint",
  "license": "MIT",
  "dependencies": {
    "markdownlint": "^0.40.0",
    "markdownlint-rule-helpers": "^0.30.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@codemirror/lint": "^6.9.2",
    "@types/diff-match-patch": "^1.0.36",
    "@types/markdownlint-rule-helpers": "^0.21.6",
    "@types/node": "^25.0.9",
    "auto-changelog": "^2.5.0",
    "builtin-modules": "^5.0.0",
    "diff-match-patch": "^1.0.5",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.4",
    "esbuild-plugin-copy": "^2.1.1",
    "esbuild-plugin-tsc": "^0.6.0",
    "eslint": "^9.0.0",
    "eslint-plugin-obsidianmd": "^0.2.9",
    "globals": "^17.0.0",
    "jsonc-parser": "^3.3.1",
    "obsidian": "^1.12.3",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "markdown-it": "14.1.1"
  },
  "auto-changelog": {
    "backfillLimit": false,
    "commitLimit": false,
    "ignoreCommitPattern": "(🔖|🔨|🧹|changelog|release|Update README).*",
    "replaceText": {
      "([;.,] [rR]esolves) #\\d+\\.?\\s*$": "$1",
      "([;.,] [Ff]ixes) #\\d+\\.?\\s*$": "$1"
    }
  }
}
